{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skill Desktop",
  "version": "0.1.0",
  "identifier": "dev.hojinlee.skill-desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Skill Desktop",
        "width": 1180,
        "height": 780,
        "minWidth": 920,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/skill-desktop-labs/skill-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGN0I5M0IyMzgzN0IxQ0EKUldUS3NUYzRzcE43TCtjY0N1ekVkaW5mYWplcWRJUVpjTmw5SVlxTlRZd2lFMktacytSVE5jWlQK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
